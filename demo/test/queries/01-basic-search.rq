# Basic full-text search across all indexed entities.
# Searches the default text field (title/rdfs:label) for the term "copper".
# Returns matching entities ranked by Lucene relevance score.

PREFIX luc: <urn:jena:lucene:index#>

SELECT ?entity ?score
WHERE {
    (?entity ?score) luc:query ("default" "copper")
}
ORDER BY DESC(?score)
