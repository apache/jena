# Facet counts with a CQL2-JSON filter applied.
# Gets operator and commodity counts for "gold" results, but only in Western Australia.
# This is the drill-down pattern: user selects a state, sees updated facets.

PREFIX luc: <urn:jena:lucene:index#>

SELECT ?field ?value ?count
WHERE {
    (?field ?value ?count) luc:facet (
        "default"
        "gold"
        '["operator", "commodity"]'
        '{"op":"=","args":[{"property":"state"},"WA"]}'
        10
    )
}
ORDER BY ?field DESC(?count)
